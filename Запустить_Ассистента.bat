@echo off
title Академический ассистент РАНХиГС (Диспетчер)
chcp 65001 > nul
cd /d "%~dp0"

echo =======================================================
echo    Запуск Диспетчера Академического Ассистента РАНХиГС
echo =======================================================
echo.

if not exist .venv\Scripts\python.exe (
    echo [ОШИБКА] Виртуальное окружение .venv не найдено!
    echo Пожалуйста, убедитесь, что папка .venv находится в папке с ботом.
    pause
    exit /b
)

echo Активирую окружение и запускаю диспетчер в режиме Standby...
.venv\Scripts\python.exe -u launcher.py

echo.
echo Диспетчер завершил работу.
pause
